# ─── JARVIS Dashboard — Data Sources Config ───────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys!

# ── Google Sheets ──────────────────────────────────────────────────────────────
# The Sheet must be shared as "Anyone with link can view"
# Sheet ID is the long string in the URL:
# https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
VITE_SHEET_ID=1pqMfgXmYTtcJ_cB95WbqWyaPDy2GH6NP2ABxfIFdV9Q

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram → get token
# Then add bot as ADMIN to your channel
# Channel ID format: @sportiviforyou  OR  -1001234567890
VITE_TELEGRAM_TOKEN=
VITE_TELEGRAM_CHANNEL=

# ── AliExpress Affiliate (Portals API) ─────────────────────────────────────────
# Get from: https://portals.aliexpress.com → Tools → API
VITE_AE_APP_KEY=
VITE_AE_APP_SECRET=
VITE_AE_TRACKING_ID=

# ── Refresh intervals (milliseconds) ──────────────────────────────────────────
VITE_REFRESH_KPI=60000       # KPI refresh: every 1 min
VITE_REFRESH_PRODUCTS=300000 # Products: every 5 min
VITE_REFRESH_INSIGHTS=120000 # Insights/alerts: every 2 min
